# ─────────────────────────────────────────────
#  AMAN MEDICAL — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────

# MongoDB connection string (from MongoDB Atlas or local)
# Example Atlas: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/aman_medical
MONGO_URI=mongodb://localhost:27017/aman_medical

# JWT secret — use a long random string (32+ chars)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_32chars

# JWT expiry for customer tokens
JWT_EXPIRES_IN=7d

# Admin credentials (stored in env, not DB)
ADMIN_EMAIL=admin@amanmedical.in
ADMIN_PASSWORD=change_this_password

# Server port
PORT=5000

# Frontend origin for CORS (your deployed frontend URL)
# Development: http://localhost:3000
# Production:  https://yourdomain.com
FRONTEND_ORIGIN=http://localhost:3000

# Node environment: development | production
NODE_ENV=development

# Razorpay API keys — get these from https://dashboard.razorpay.com/app/keys
# Use the "Test Mode" keys while developing.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Gmail SMTP — for sending the newsletter welcome email.
# GMAIL_APP_PASSWORD is a 16-character "App Password", NOT your normal Gmail password.
# Generate one at https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled).
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
